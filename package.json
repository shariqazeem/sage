{
  "name": "sage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:browser-security": "RENDER_BROWSER_TEST=1 vitest run src/lib/deputy/evidence-render.browser.test.ts src/lib/net/egress-proxy.test.ts src/lib/net/ip-classify.test.ts",
    "test:field-egress": "FIELD_TEST_ENABLED=1 vitest run src/lib/launch/field-test.test.ts",
    "test:inspection-replay": "INSPECTION_REPLAY_TEST=1 vitest run src/lib/launch/inspection-replay.browser.test.ts",
    "test:payout-replay-browser": "PAYOUT_REPLAY_BROWSER_TEST=1 vitest run src/lib/deputy/payout-replay.browser.test.ts",
    "demo:agentic-v2": "DEMO_AGENTIC=1 vitest run src/lib/launch/demo-agentic-v2.test.ts --reporter=basic",
    "demo:payout-replay": "DEMO_PAYOUT_REPLAY=1 vitest run src/lib/deputy/demo-payout-replay.test.ts --reporter=basic",
    "test:inspection-live": "INSPECTION_REPLAY_TEST=1 vitest run src/lib/launch/inspect-and-plan.integration.test.ts",
    "smoke:grounding:dryrun": "GROUNDING_SMOKE_DRYRUN=1 vitest run src/lib/launch/mission-grounding-smoke.live.test.ts --reporter=basic",
    "smoke:grounding": "GROUNDING_SMOKE=1 GROUNDING_SMOKE_CONFIRM=CALL_CAP_6 vitest run src/lib/launch/mission-grounding-smoke.live.test.ts --reporter=basic",
    "smoke:structured:dryrun": "GROUNDING_STRUCTURED_DRYRUN=1 vitest run src/lib/launch/mission-grounding-structured-smoke.live.test.ts --reporter=basic",
    "smoke:structured": "GROUNDING_STRUCTURED=1 GROUNDING_STRUCTURED_CONFIRM=CALL_CAP_5 vitest run src/lib/launch/mission-grounding-structured-smoke.live.test.ts --reporter=basic",
    "smoke:semantic:dryrun": "GROUNDING_SEMANTIC_DRYRUN=1 vitest run src/lib/launch/mission-grounding-semantic-smoke.live.test.ts --reporter=basic",
    "smoke:semantic": "GROUNDING_SEMANTIC=1 GROUNDING_SEMANTIC_CONFIRM=CALL_CAP_6 vitest run src/lib/launch/mission-grounding-semantic-smoke.live.test.ts --reporter=basic",
    "bakeoff:critic:dryrun": "GROUNDING_CRITIC_DRYRUN=1 vitest run src/lib/launch/grounding-critic-bakeoff.live.test.ts --reporter=basic",
    "bakeoff:critic": "GROUNDING_CRITIC_BAKEOFF=1 GROUNDING_CRITIC_BAKEOFF_CONFIRM=CALL_CAP_6 vitest run src/lib/launch/grounding-critic-bakeoff.live.test.ts --reporter=basic",
    "bakeoff:critic2:dryrun": "GROUNDING_CRITIC2_DRYRUN=1 vitest run src/lib/launch/grounding-critic-bakeoff-v2.live.test.ts --reporter=basic",
    "bakeoff:critic2": "GROUNDING_CRITIC2=1 GROUNDING_CRITIC_BAKEOFF2_CONFIRM=CALL_CAP_4 vitest run src/lib/launch/grounding-critic-bakeoff-v2.live.test.ts --reporter=basic",
    "canary:smoke:dryrun": "GROUNDING_CANARY_SMOKE_DRYRUN=1 vitest run src/lib/launch/mission-canary-smoke.live.test.ts --reporter=basic",
    "canary:smoke": "GROUNDING_CANARY_SMOKE=1 GROUNDING_CANARY_SMOKE_CONFIRM=CALL_CAP_2 vitest run src/lib/launch/mission-canary-smoke.live.test.ts --reporter=basic",
    "canary:closure": "SAGE_DB_PATH=$(mktemp -d)/closure.db CANARY_CLOSURE=1 CANARY_CLOSURE_CONFIRM=CALL_CAP_2 vitest run src/lib/launch/canary-closure.live.test.ts --reporter=basic",
    "canary:closure:det": "SAGE_DB_PATH=$(mktemp -d)/closure-det.db CANARY_CLOSURE_DET=1 vitest run src/lib/launch/canary-closure.live.test.ts --reporter=basic",
    "deputy:watch": "node --env-file-if-exists=.env scripts/deputy-watch.mjs",
    "preflight": "node --env-file-if-exists=.env scripts/preflight.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "closure:v2:dry": "SAGE_DB_PATH=$(mktemp -d)/ccv2.db CANARY_CLOSURE_V2_DRY=1 vitest run src/lib/launch/canary-runtime-closure-v2.live.test.ts --reporter=basic",
    "closure:v2": "SAGE_DB_PATH=$(mktemp -d)/ccv2.db CANARY_CLOSURE_V2=1 CANARY_CLOSURE_V2_CONFIRM=CALL_CAP_2 vitest run src/lib/launch/canary-runtime-closure-v2.live.test.ts --reporter=basic",
    "demo:self-canary": "DEMO_SELF_CANARY=1 vitest run src/lib/deputy/demo-self-canary.test.ts --reporter=basic",
    "canary:preflight": "node scripts/canary-release-preflight.mjs",
    "e2e:money-boundary": "SAGE_DB_PATH=$(mktemp -d)/e2e.db MONEY_BOUNDARY_E2E=1 vitest run src/lib/campaigns/attach-policy.integration.test.ts --reporter=basic"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fetch-to-node": "^2.1.0",
    "goatx402-sdk-server": "^0.1.1",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.16",
    "next": "15.5.19",
    "playwright": "^1.61.0",
    "radix-ui": "^1.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.53.1",
    "zod": "^4.4.3",
    "ipaddr.js": "^1.9.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  }
}
