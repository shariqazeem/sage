{
  "name": "sage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:browser-security": "RENDER_BROWSER_TEST=1 vitest run src/lib/deputy/evidence-render.browser.test.ts src/lib/net/egress-proxy.test.ts src/lib/net/ip-classify.test.ts",
    "test:field-egress": "FIELD_TEST_ENABLED=1 vitest run src/lib/launch/field-test.test.ts",
    "test:inspection-replay": "INSPECTION_REPLAY_TEST=1 vitest run src/lib/launch/inspection-replay.browser.test.ts",
    "demo:agentic-v2": "DEMO_AGENTIC=1 vitest run src/lib/launch/demo-agentic-v2.test.ts --reporter=basic",
    "test:inspection-live": "INSPECTION_REPLAY_TEST=1 vitest run src/lib/launch/inspect-and-plan.integration.test.ts",
    "deputy:watch": "node --env-file-if-exists=.env scripts/deputy-watch.mjs",
    "preflight": "node --env-file-if-exists=.env scripts/preflight.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fetch-to-node": "^2.1.0",
    "goatx402-sdk-server": "^0.1.1",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.16",
    "next": "15.5.19",
    "playwright": "^1.61.0",
    "radix-ui": "^1.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.53.1",
    "zod": "^4.4.3",
    "ipaddr.js": "^1.9.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  }
}
