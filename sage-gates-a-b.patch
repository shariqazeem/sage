+  const wrongAutopayTotal = wrongAutopayRows.length;
+  const knownGapWrongAutopays = wrongAutopayRows.filter((r) => r.knownGap).length;
+  const unexpectedWrongAutopays = wrongAutopayTotal - knownGapWrongAutopays;
