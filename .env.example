# Sage — environment reference. Copy to `.env` and fill in.
# Next.js loads `.env` automatically. NOTHING real here — placeholders only.
# Missing values degrade honestly (heuristic brain, "pending" x402, etc.);
# malformed values hard-fail at boot (see src/lib/env.ts).

# ── Network + RPC ───────────────────────────────────────────────────────
DEPUTY_NETWORK=metis-sepolia            # metis-sepolia | metis-andromeda
METIS_SEPOLIA_RPC=https://sepolia.metisdevops.link
METIS_RPC=https://andromeda.metis.io/?owner=1088
GOAT_RPC_URL=https://rpc.goat.network

# ── On-chain addresses (filled after deploying the PolicyVault) ─────────
NEXT_PUBLIC_VAULT_ADDRESS=0x...         # the funding vault campaigns pay from
NEXT_PUBLIC_USDC_ADDRESS=0x...
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_OPERATOR_ADDRESS=0x...      # public address of the operator key
NEXT_PUBLIC_KILL_VAULT_ADDRESS=0x...
GOAT_FACTORY_ADDRESS=0x...              # GOAT mainnet vault stack (optional)
GOAT_VAULT_ADDRESS=0x...

# ── Signing keys — SERVER ONLY, NEVER COMMIT, NEVER LOG ─────────────────
# The Deputy signs vault writes with this. Also read from contracts/.env PRIVATE_KEY.
OPERATOR_PRIVATE_KEY=0x...
GOAT_AGENT_PRIVATE_KEY=0x...            # GOAT mainnet (chainId 2345) signer

# ── LLM brain — provider-agnostic (OpenAI-compatible) ──────────────────
# Prefer LLM_*; COMMONSTACK_* is the legacy fallback. Missing key → heuristic.
LLM_BASE_URL=https://api.commonstack.ai/v1
LLM_API_KEY=
LLM_MODEL=google/gemini-3.1-flash-lite-preview
COMMONSTACK_API_KEY=
COMMONSTACK_BASE_URL=https://api.commonstack.ai/v1
DEPUTY_MODEL=

# ── x402 (GOAT) merchant credentials — optional payment rail ───────────
GOATX402_API_KEY=
GOATX402_API_SECRET=
GOATX402_MERCHANT_ID=
GOATX402_API_URL=https://x402-api.goat.network

# ── ERC-8004 identity (written by scripts/register-erc8004.mjs) ────────
ERC8004_AGENT_ID=                       # numeric agent id; presence = registered
ERC8004_AGENT_ADDRESS=0x...
ERC8004_AGENT_NAME=Sage

# ── Telegram (optional bot + notifications) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                       # private held/paid operator pings
TELEGRAM_WEBHOOK_SECRET=                # enables POST /api/telegram/webhook
TELEGRAM_ANNOUNCE_CHAT_ID=              # public per-campaign announces

# ── Autonomy + public URLs + secrets ───────────────────────────────────
DEPUTY_AUTOPILOT_MAINNET=false          # arm auto-pay of REAL money on GOAT 2345
DEPUTY_DEBUG=
NEXT_PUBLIC_APP_URL=https://your-deploy.example
NEXT_PUBLIC_SITE_URL=https://your-deploy.example
SAGE_SESSION_SECRET=                    # REQUIRED in production (SIWE sessions)
DEPUTY_CRON_SECRET=                     # authorizes the autopilot sweep
CRON_SECRET=                            # authorizes Vercel Cron
