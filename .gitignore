# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets are NEVER committed; the .example (placeholders) is kept
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Reference design prototype (extracted zip)
/Sage Master Design Prompt/

# Local dev database (SQLite)
/var/

# Claude Code local config
/.claude/

# Design prototype archive (not needed to build)
/Sage Master Design Prompt.zip

# Foundry deps + heavy artifacts. The ABIs in contracts/out/*.sol/ are KEPT so
# `npm run build` works on a fresh clone; only the big/regenerable bits are ignored.
/contracts/lib/
/contracts/cache/
/contracts/broadcast/
/contracts/out/build-info/

# Field Test screenshots — generated at runtime, never committed.
/public/field-tests/

# transient smoke checkpoint (never committed; evidence artifact IS committed)
promotion-evidence/*.checkpoint.json
