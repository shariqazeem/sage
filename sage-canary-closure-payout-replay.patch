+    const changedAction = compile({ set: mkSet([fact({})], [trans({ locator: { role: "button", accessibleName: "Refresh" } })]) });
+    if ("probe" in changedAction) expect(changedAction.probe.probeDigest).not.toBe(base.probe.probeDigest);
