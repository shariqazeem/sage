+    if ("probe" in changedOutcome) expect(changedOutcome.probe.probeDigest).not.toBe(base.probe.probeDigest);
+  });
+  it("set-like arrays are canonicalized (sourceFactIds sorted) so ordering never changes the digest", () => {
