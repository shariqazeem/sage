+
+describe("compileMissionProbe — the rejection matrix (bounded codes, no probe)", () => {
+  const reject = (r: ReturnType<typeof compile>) => ("rejected" in r ? r.rejected : "COMPILED");
+  it("non action_outcome → not_action_outcome", () => {
